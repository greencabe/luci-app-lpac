From: As Tsaqib <0xfiqks@gmail.com>
Date: Mon, 20 Jul 2026 00:00:00 +0800
Subject: [PATCH] notification: parse sequence numbers as strict uint32 values

The applets previously accepted signs, whitespace, trailing junk, and values
larger than uint32_t. On 64-bit hosts an out-of-range value was truncated when
passed to the eUICC API, potentially operating on a different notification.

Share a decimal-only overflow-checked parser between all three notification
applets. Keep sequence zero valid and fail explicitly instead of reporting
success after ignoring an invalid argument.
---
 src/applet/notification/dump.c                  | 13 +++++--------
 src/applet/notification/notification_sequence.c | 31 +++++++++++++++++++++++++++++++
 src/applet/notification/notification_sequence.h | 10 ++++++++++
 src/applet/notification/process.c               | 15 +++++----------
 src/applet/notification/remove.c                | 16 +++++-----------
 5 files changed, 56 insertions(+), 29 deletions(-)
 create mode 100644 src/applet/notification/notification_sequence.c
 create mode 100644 src/applet/notification/notification_sequence.h

--- a/src/applet/notification/dump.c
+++ b/src/applet/notification/dump.c
@@ -1,5 +1,6 @@
 #include "notification_common.h"
 #include "process.h"
+#include "notification_sequence.h"
 
 #include <euicc/es10b.h>
 #include <euicc/es10c.h>
@@ -78,14 +79,10 @@ static int applet_main(const int argc, c
 
     } else {
         for (int i = optind; i < argc; i++) {
-            errno = 0;
-            char *str_end;
-            const unsigned long seqNumber = strtoul(argv[i], &str_end, 10);
-            // Although POSIX said user should check errno instead of return value,
-            // but errno may not be set when no conversion is performed according to C99.
-            // Check nptr is same as str_end to ensure there is no conversion.
-            if (argv[i] == str_end || errno != 0) {
-                continue;
+            uint32_t seqNumber;
+            if (!notification_parse_sequence_number(argv[i], &seqNumber)) {
+                jprint_error("seqNumber", "invalid unsigned 32-bit decimal");
+                return -1;
             }
             if (!retrieve_notification(eid, seqNumber)) {
                 fret = -1;
--- /dev/null
+++ b/src/applet/notification/notification_sequence.c
@@ -0,0 +1,31 @@
+// SPDX-License-Identifier: AGPL-3.0-only
+
+#include "notification_sequence.h"
+
+#include <stddef.h>
+#include <stdint.h>
+
+bool notification_parse_sequence_number(const char *value, uint32_t *sequence_number) {
+    uint32_t parsed = 0;
+
+    if (value == NULL || value[0] == '\0' || sequence_number == NULL) {
+        return false;
+    }
+
+    for (const unsigned char *p = (const unsigned char *)value; *p != '\0'; p++) {
+        uint32_t digit;
+
+        if (*p < '0' || *p > '9') {
+            return false;
+        }
+
+        digit = (uint32_t)(*p - '0');
+        if (parsed > (UINT32_MAX - digit) / 10U) {
+            return false;
+        }
+        parsed = parsed * 10U + digit;
+    }
+
+    *sequence_number = parsed;
+    return true;
+}
--- /dev/null
+++ b/src/applet/notification/notification_sequence.h
@@ -0,0 +1,10 @@
+// SPDX-License-Identifier: AGPL-3.0-only
+
+#pragma once
+
+#include <stdbool.h>
+#include <stdint.h>
+
+// Accept only a non-empty string of ASCII decimal digits in uint32_t range.
+// Sequence number zero is valid.
+bool notification_parse_sequence_number(const char *value, uint32_t *sequence_number);
