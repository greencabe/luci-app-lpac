From: As Tsaqib <0xfiqks@gmail.com>
Date: Mon, 20 Jul 2026 00:00:00 +0800
Subject: [PATCH] driver: curl: bound provider response memory

Provider responses are accumulated in memory before JSON and base64 parsing.
The write callback previously multiplied and added untrusted chunk sizes
without overflow checks, overwrote the only allocation pointer on realloc
failure, and allowed a TLS-valid endpoint to consume memory without a bound.

Reject response bodies above 16 MiB, check each arithmetic step before
allocation, and retain the old buffer when realloc fails. Report resource
diagnostics only on stderr so the lpac NDJSON protocol remains intact.
---
 driver/http/curl.c | 25 ++++++++++++++++++++-----
 1 file changed, 20 insertions(+), 5 deletions(-)

--- a/driver/http/curl.c
+++ b/driver/http/curl.c
@@ -31,6 +31,8 @@ typedef int CURLINFO;
 static void *libcurl_interface_dlhandle = NULL;
 #endif
 
+#define HTTP_RESPONSE_MAX_SIZE ((size_t)16U * 1024U * 1024U)
+
 struct http_trans_response_data {
     uint8_t *data;
     size_t size;
@@ -50,15 +52,28 @@ static struct libcurl_interface {
 } libcurl;
 
 static size_t http_trans_write_callback(void *contents, size_t size, size_t nmemb, void *userp) {
-    size_t realsize = size * nmemb;
+    size_t realsize;
     struct http_trans_response_data *mem = (struct http_trans_response_data *)userp;
+    uint8_t *expanded;
+
+    if (size != 0 && nmemb > HTTP_RESPONSE_MAX_SIZE / size) {
+        fprintf(stderr, "provider response chunk exceeds memory limit\n");
+        return 0;
+    }
+
+    realsize = size * nmemb;
+    if (mem->size > HTTP_RESPONSE_MAX_SIZE ||
+        realsize > HTTP_RESPONSE_MAX_SIZE - mem->size) {
+        fprintf(stderr, "provider response exceeds memory limit\n");
+        return 0;
+    }
 
-    mem->data = realloc(mem->data, mem->size + realsize + 1);
-    if (mem->data == NULL) {
-        /* out of memory! */
-        printf("not enough memory (realloc returned NULL)\n");
+    expanded = realloc(mem->data, mem->size + realsize + 1U);
+    if (expanded == NULL) {
+        fprintf(stderr, "not enough memory for provider response\n");
         return 0;
     }
+    mem->data = expanded;
 
     memcpy(&(mem->data[mem->size]), contents, realsize);
     mem->size += realsize;
