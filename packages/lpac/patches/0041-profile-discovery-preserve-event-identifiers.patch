From: As Tsaqib <0xfiqks@gmail.com>
Date: Mon, 20 Jul 2026 00:00:00 +0800
Subject: [PATCH] profile: discovery: preserve SM-DS event identifiers

An SM-DS response pairs each RSP server address with an EventID. The EventID
is the MatchingID needed to download that discovered profile, but the legacy
discovery output discards it.

Add a parallel libeuicc API and a `profile discovery -j` mode which returns
objects containing both values. Keep the existing API and default array of
address strings unchanged. Parse provider strings into separately allocated,
bounded, NUL-terminated buffers and cap the number of entries.
---
 euicc/es11_event.c              | 95 +++++++++++++++++++++++++++++++++++++++++
 euicc/es11_event.h              | 29 +++++++++++++
 euicc/es9p.c                    | 39 +++++++++++++++++
 euicc/es9p.h                    |  6 +++
 src/applet/profile/discovery.c  | 36 ++++++++++++----
 utils/lpac/utils.h              |  3 ++
 6 files changed, 200 insertions(+), 8 deletions(-)
 create mode 100644 euicc/es11_event.c
 create mode 100644 euicc/es11_event.h

--- /dev/null
+++ b/euicc/es11_event.c
@@ -0,0 +1,95 @@
+// SPDX-License-Identifier: LGPL-2.1-only
+
+#include "es11_event.h"
+
+#include <stdlib.h>
+#include <string.h>
+
+static char *duplicate_bounded_string(const char *value, size_t maximum_length) {
+    size_t length = 0;
+    char *copy;
+
+    if (value == NULL) {
+        return NULL;
+    }
+
+    while (length <= maximum_length && value[length] != '\0') {
+        length++;
+    }
+    if (length == 0 || length > maximum_length) {
+        return NULL;
+    }
+
+    copy = malloc(length + 1);
+    if (copy == NULL) {
+        return NULL;
+    }
+    memcpy(copy, value, length);
+    copy[length] = '\0';
+    return copy;
+}
+
+void es11_event_list_free_all(struct es11_event_entry *events) {
+    if (events == NULL) {
+        return;
+    }
+
+    for (size_t i = 0; events[i].event_id != NULL || events[i].rsp_server_address != NULL; i++) {
+        free(events[i].event_id);
+        free(events[i].rsp_server_address);
+    }
+    free(events);
+}
+
+int es11_event_entries_parse(struct es11_event_entry **events, const cJSON *event_entries) {
+    struct es11_event_entry *parsed = NULL;
+    int entry_count;
+
+    if (events == NULL) {
+        return -1;
+    }
+    *events = NULL;
+
+    if (!cJSON_IsArray(event_entries)) {
+        return -1;
+    }
+
+    entry_count = cJSON_GetArraySize(event_entries);
+    if (entry_count < 0 || entry_count > (int)ES11_EVENT_ENTRIES_MAX) {
+        return -1;
+    }
+
+    parsed = calloc((size_t)entry_count + 1U, sizeof(*parsed));
+    if (parsed == NULL) {
+        return -1;
+    }
+
+    for (int i = 0; i < entry_count; i++) {
+        const cJSON *entry = cJSON_GetArrayItem(event_entries, i);
+        const cJSON *event_id;
+        const cJSON *server_address;
+
+        if (!cJSON_IsObject(entry)) {
+            goto error;
+        }
+        event_id = cJSON_GetObjectItemCaseSensitive(entry, "eventId");
+        server_address = cJSON_GetObjectItemCaseSensitive(entry, "rspServerAddress");
+        if (!cJSON_IsString(event_id) || !cJSON_IsString(server_address)) {
+            goto error;
+        }
+
+        parsed[i].event_id = duplicate_bounded_string(cJSON_GetStringValue(event_id), ES11_EVENT_ID_MAX_LENGTH);
+        parsed[i].rsp_server_address =
+            duplicate_bounded_string(cJSON_GetStringValue(server_address), ES11_RSP_SERVER_ADDRESS_MAX_LENGTH);
+        if (parsed[i].event_id == NULL || parsed[i].rsp_server_address == NULL) {
+            goto error;
+        }
+    }
+
+    *events = parsed;
+    return 0;
+
+error:
+    es11_event_list_free_all(parsed);
+    return -1;
+}
--- /dev/null
+++ b/euicc/es11_event.h
@@ -0,0 +1,29 @@
+// SPDX-License-Identifier: LGPL-2.1-only
+
+#pragma once
+
+#include <cjson/cJSON.h>
+
+#include <stddef.h>
+
+/*
+ * Bound provider-controlled SM-DS data before exposing it to callers. The
+ * EventID is opaque MatchingID data; 4096 bytes also matches the maximum
+ * canonical activation string accepted by the LuCI consumer.
+ */
+#define ES11_EVENT_ENTRIES_MAX 64U
+#define ES11_EVENT_ID_MAX_LENGTH 4096U
+#define ES11_RSP_SERVER_ADDRESS_MAX_LENGTH 255U
+
+struct es11_event_entry {
+    char *event_id;
+    char *rsp_server_address;
+};
+
+int es11_event_entries_parse(struct es11_event_entry **events, const cJSON *event_entries);
+
+/*
+ * Free a sentinel-terminated list returned by es11_event_entries_parse() or
+ * es11_authenticate_client_details().
+ */
+void es11_event_list_free_all(struct es11_event_entry *events);
